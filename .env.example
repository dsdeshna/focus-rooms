# ============================================================
# Focus Rooms — Environment Variables
# ============================================================

# Supabase Configuration
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Note: Never commit or expose your service_role key in the frontend.
# SUPABASE_SERVICE_ROLE_KEY is only needed if you use Edge Functions.

# ── Docker / Kubernetes ──
# These are injected via K8s ConfigMap/Secret in production.
# Only needed locally for development.
NODE_ENV=development
PORT=3000
